# Copie para .env.local (nunca commite senhas).
# Na Vercel: Settings → Environment Variables.

DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Opcional: limite de conexões no pool (padrão 5)
# DB_POOL_LIMIT=5

# API de envio de e-mail (send.cadbr.com.br) — docs/EMAIL_API_ENVIO.md
# Se EMAIL_API_URL contiver "your-", o envio fica desativado.
EMAIL_API_URL=https://send.cadbr.com.br/sendCron
# Destino da notificação interna de novo cadastro (quando o utilizador aceita no formulário)
EMAIL_NOTIFICATION_EMAIL=

# URLs públicas do portal (card Enviar documentos)
# NEXT_PUBLIC_PORTAL_URL=https://fornecedor.cadbrasil.com.br

# Valor exibido no modal de pagamento (opcional; deve coincidir com EFI_COBRANCA_VALOR_CENTS)
# NEXT_PUBLIC_COBRANCA_VALOR_CENTS=9900

# --- Efí (Gerencianet) — boleto one-step e PIX imediato ---
# Certificate .p12 em Base64 (uma linha). Conta: https://sejaefi.com.br
# EFI_SANDBOX=true
# EFI_CLIENT_ID=
# EFI_CLIENT_SECRET=
# EFI_CERTIFICATE_BASE64=
# Chave PIX cadastrada na Efí (evp, e-mail, CPF ou CNPJ conforme sua conta)
# EFI_PIX_CHAVE=
# Valor da cobrança em centavos (ex.: 9900 = R$ 99,00)
# EFI_COBRANCA_VALOR_CENTS=9900
# Dias até vencimento do boleto (padrão 3)
# EFI_BOLETO_DIAS_VENCIMENTO=3
# Expiração da cobrança PIX em segundos (padrão 3600)
# EFI_PIX_EXPIRACAO_SEGUNDOS=3600
# Webhook de notificação Efí (opcional)
# EFI_NOTIFICATION_URL=https://seu-dominio.com/api/webhooks/efi

# Token da API CNPJ.ws (consulta de CNPJ no formulário)
# CNPJ_WS_API_TOKEN=
